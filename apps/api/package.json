{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "pnpm --filter @inv/shared build && tsc -p tsconfig.json",
    "start": "node dist/apps/api/src/server.js",
    "typecheck": "tsc --noEmit && tsc -p tsconfig.test.json --noEmit && tsc -p src/pdf/tsconfig.pdf.json --noEmit",
    "test": "vitest run",
    "seed": "tsx src/seed.ts"
  },
  "dependencies": {
    "@inv/shared": "workspace:*",
    "@prisma/client": "^5.15.0",
    "@react-pdf/renderer": "^3.4.4",
    "fastify": "^4.27.0",
    "fastify-type-provider-zod": "^2.1.0",
    "react": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "prisma": "^5.15.0",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "packageManager": "pnpm@11.1.0+sha512.0c44e842e5686b2c061a81adda8b2258bd8818e9704b2cf2c63d56b931a7b2e910092e085027003b96ca3911ab56a07f6df5abaed2be9925034cdd686a535b14"
}
